generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------
// Enums
// ---------------------------------------------

enum Role {
  CUSTOMER
  STAFF
  BRANCH_MANAGER
  ADMIN
  SUPER_ADMIN
}

enum VehicleCategory {
  ECONOMY
  SUV
  LUXURY
  VAN
  SPORTS
  ELECTRIC
}

enum VehicleStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  RESERVED
  RETIRED
}

enum TransmissionType {
  AUTOMATIC
  MANUAL
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentProvider {
  STRIPE
  CHAPA
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  CARD
  CASH
  BANK_TRANSFER
  TELEBIRR
  CBE_BIRR
  HELLOCASH
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  BOOKING
  PAYMENT
  SYSTEM
  PROMOTION
  MAINTENANCE
}

enum InspectionType {
  PICKUP
  RETURN
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum AIRole {
  USER
  ASSISTANT
  SYSTEM
}

// ---------------------------------------------
// Core: Users & Auth
// ---------------------------------------------

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  password             String
  firstName            String
  lastName             String
  phone                String?
  role                 Role      @default(CUSTOMER)
  avatarUrl            String?
  driverLicenseNumber  String?
  licenseExpiry        DateTime?
  verificationStatus   VerificationStatus @default(PENDING)
  loyaltyPoints        Int       @default(0)
  corporateAccountId   String?
  corporateAccount     CorporateAccount? @relation(fields: [corporateAccountId], references: [id])
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  refreshTokens        RefreshToken[]
  bookings             Booking[]
  reviews              Review[]
  wishlist             Wishlist[]
  notifications        Notification[]
  verificationDocs     VerificationDocument[]
  aiConversations      AIConversation[]
  auditLogs            AuditLog[]

  @@index([email])
  @@index([role])
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  revoked    Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
}

// ---------------------------------------------
// Locations
// ---------------------------------------------

model Location {
  id        String   @id @default(cuid())
  name      String
  address   String
  city      String
  country   String
  latitude  Float?
  longitude Float?
  phone     String?
  createdAt DateTime @default(now())

  vehicles  Vehicle[]
  bookings  Booking[]
}

// ---------------------------------------------
// Vehicles / Fleet
// ---------------------------------------------

model Vehicle {
  id            String            @id @default(cuid())
  name          String
  brand         String
  category      VehicleCategory
  transmission  TransmissionType
  fuel          FuelType
  seats         Int
  pricePerDay   Float
  status        VehicleStatus     @default(AVAILABLE)
  plate         String            @unique
  description   String?
  mileage       Int               @default(0)
  year          Int
  locationId    String?
  location      Location?         @relation(fields: [locationId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  images              VehicleImage[]
  bookings            Booking[]
  reviews             Review[]
  maintenanceRecords  MaintenanceRecord[]
  wishlistedBy        Wishlist[]

  @@index([category])
  @@index([status])
}

model VehicleImage {
  id         String   @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  url        String
  isPrimary  Boolean  @default(false)

  @@index([vehicleId])
}

// ---------------------------------------------
// Bookings
// ---------------------------------------------

model Booking {
  id                 String        @id @default(cuid())
  userId             String
  user               User          @relation(fields: [userId], references: [id])
  vehicleId          String
  vehicle            Vehicle       @relation(fields: [vehicleId], references: [id])
  locationId         String?
  location           Location?     @relation(fields: [locationId], references: [id])
  startDate          DateTime
  endDate            DateTime
  totalPrice         Float
  status             BookingStatus @default(PENDING)
  couponId           String?
  coupon             Coupon?       @relation(fields: [couponId], references: [id])
  insuranceAddOn     Boolean       @default(false)
  deliveryRequested  Boolean       @default(false)
  deliveryAddress    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  payment       Payment?
  review        Review?
  inspections   InspectionReport[]

  @@index([userId])
  @@index([vehicleId])
  @@index([status])
  @@index([startDate, endDate])
}

// ---------------------------------------------
// Payments
// ---------------------------------------------

model Payment {
  id                     String          @id @default(cuid())
  bookingId              String          @unique
  booking                Booking         @relation(fields: [bookingId], references: [id])
  amount                 Float
  currency               String          @default("usd")
  provider               PaymentProvider @default(STRIPE)
  method                 PaymentMethod   @default(CARD)
  status                 PaymentStatus   @default(PENDING)
  stripePaymentIntentId  String?
  chapaTxRef             String?         @unique
  invoiceUrl             String?
  createdAt              DateTime        @default(now())

  @@index([status])
  @@index([provider])
}

// ---------------------------------------------
// Reviews
// ---------------------------------------------

model Review {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@index([vehicleId])
}

// ---------------------------------------------
// Coupons & Loyalty
// ---------------------------------------------

model Coupon {
  id         String     @id @default(cuid())
  code       String     @unique
  type       CouponType
  value      Float
  maxUses    Int?
  usedCount  Int        @default(0)
  expiresAt  DateTime?
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())

  bookings   Booking[]
}

// ---------------------------------------------
// Wishlist
// ---------------------------------------------

model Wishlist {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, vehicleId])
}

// ---------------------------------------------
// Notifications
// ---------------------------------------------

model Notification {
  id         String            @id @default(cuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  title      String
  message    String
  read       Boolean           @default(false)
  createdAt  DateTime          @default(now())

  @@index([userId, read])
}

// ---------------------------------------------
// Maintenance
// ---------------------------------------------

model MaintenanceRecord {
  id                 String            @id @default(cuid())
  vehicleId          String
  vehicle            Vehicle           @relation(fields: [vehicleId], references: [id])
  status             MaintenanceStatus @default(SCHEDULED)
  description        String
  scheduledDate      DateTime
  completedDate      DateTime?
  odometerAtService  Int?
  cost               Float?
  createdAt          DateTime          @default(now())

  @@index([vehicleId])
}

// ---------------------------------------------
// Inspections (pickup/return damage reports)
// ---------------------------------------------

model InspectionReport {
  id            String          @id @default(cuid())
  bookingId     String
  booking       Booking         @relation(fields: [bookingId], references: [id])
  type          InspectionType
  notes         String?
  photos        String[]
  damageFound   Boolean         @default(false)
  inspectedBy   String?
  createdAt     DateTime        @default(now())

  @@index([bookingId])
}

// ---------------------------------------------
// Driver Verification (KYC)
// ---------------------------------------------

model VerificationDocument {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id])
  documentType  String
  documentUrl   String
  status        VerificationStatus  @default(PENDING)
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime            @default(now())

  @@index([userId])
}

// ---------------------------------------------
// Corporate Accounts
// ---------------------------------------------

model CorporateAccount {
  id              String   @id @default(cuid())
  companyName     String
  contactEmail    String
  contactPhone    String?
  billingAddress  String?
  createdAt       DateTime @default(now())

  employees  User[]
}

// ---------------------------------------------
// AI Assistant conversation history
// ---------------------------------------------

model AIConversation {
  id         String       @id @default(cuid())
  userId     String?
  user       User?        @relation(fields: [userId], references: [id])
  sessionId  String       @unique
  createdAt  DateTime     @default(now())

  messages   AIMessage[]
}

model AIMessage {
  id              String          @id @default(cuid())
  conversationId  String
  conversation    AIConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            AIRole
  content         String
  createdAt       DateTime        @default(now())

  @@index([conversationId])
}

// ---------------------------------------------
// Audit Log (compliance)
// ---------------------------------------------

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
}