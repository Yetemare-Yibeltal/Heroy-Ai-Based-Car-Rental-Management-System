# ---------------------------------------------
# Server
# ---------------------------------------------
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000

# ---------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/heroy_dev?schema=public"

# ---------------------------------------------
# Auth (JWT)
# ---------------------------------------------
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ---------------------------------------------
# AI Assistant (Anthropic Claude)
# ---------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---------------------------------------------
# Payments (Stripe)
# ---------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# ---------------------------------------------
# Payments (Chapa - Ethiopian payment gateway)
# ---------------------------------------------
CHAPA_SECRET_KEY=CHASECK_TEST-your_key_here
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-your_key_here
CHAPA_WEBHOOK_SECRET=your_chapa_webhook_secret
CHAPA_BASE_URL=https://api.chapa.co/v1
# ---------------------------------------------
# Email (Resend or SMTP)
# ---------------------------------------------
EMAIL_FROM="HEROY <no-reply@heroy.example>"
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password

# ---------------------------------------------
# SMS (Twilio) - Phase 13
# ---------------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+10000000000

# ---------------------------------------------
# File uploads (Cloudinary) - Phase 13
# ---------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# ---------------------------------------------
# Monitoring (Sentry) - Phase 13
# ---------------------------------------------
SENTRY_DSN=

# ---------------------------------------------
# Rate limiting
# ---------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
